{
  "expo": {
    "name": "من أنا",
    "slug": "man-ana-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.nexura.manana"
    },
    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3363485131173314~4509242134"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.1.20",
            "packagingOptions": {
              "pickFirst": [
                "**/kotlin-stdlib/*.kotlin_module",
                "**/kotlin-stdlib-*.kotlin_module",
                "META-INF/*.kotlin_module"
              ]
            }
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "eb7ca4ea-8357-4151-b902-2c75f07de305"
      }
    },
    "owner": "imededdinesakhi"
  },
  "cli": {
    "appVersionSource": "local"
  }
}